FIREFLIES_SECRET=
FIREFLIES_API_KEY=
# Used by summarizer.js to condense the raw Fireflies summary before Telegram send.
# If unset, the summarizer step is skipped and the raw summary is sent as-is.
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
# Ops/failure alerts + unrouted-meeting fallback (a personal DM chat_id is fine)
TELEGRAM_OPS_CHAT_ID=
# Per-meeting-series routing — add a rule in index.js's meetingRouter list for each new one
TELEGRAM_CHAT_BOND_NEBULA=
TELEGRAM_CHAT_BOND_TEAM=
TELEGRAM_CHAT_ERN_EXEC_STANDUP=
TELEGRAM_CHAT_ERN_SUPER_TEAM=
# Shared secret for the pre-meeting Cloud Routine's /relay/telegram-agenda calls (ADR-0004).
# Generate with `openssl rand -hex 32`. The routine never gets TELEGRAM_BOT_TOKEN or a real
# chat_id — only this secret and a symbolic chatKey (see relay-chat-keys.js).
RELAY_SECRET=
PORT=3000
